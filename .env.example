# Hive Environment Variables
# Copy to .env and adjust for your environment.

# ── Core ──────────────────────────────────────────────────────────────
# Role this instance plays: manager | worker | agent
HIVE_ROLE=manager

# Enable development mode (skips SvelteKit child process, uses dev paths)
# HIVE_DEV=1

# Persistent data directory (password files, NATS store, etc.)
HIVE_DATA_DIR=/data

# ── Networking / Ports ────────────────────────────────────────────────
# Go API server port (exposed to users)
HIVE_API_PORT=8080

# SvelteKit internal port (proxied by Go, not exposed directly)
HIVE_UI_PORT=3000

# Embedded NATS port (used by agents/workers in multi-node mode)
HIVE_NATS_PORT=4222

# NATS URL for worker/agent to connect to the manager
# HIVE_NATS_URL=nats://hive-manager:4222

# ── Database ──────────────────────────────────────────────────────────
# Postgres connection string (auto-populated by bootstrap in managed mode)
# DATABASE_URL=postgres://hive:secret@hive-postgres:5432/hive?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────
# BetterAuth base URL for session validation (defaults to local SvelteKit)
# HIVE_AUTH_URL=http://127.0.0.1:3000

# ── Docker / Swarm ───────────────────────────────────────────────────
# Docker socket path
# DOCKER_HOST=unix:///var/run/docker.sock

# Docker image reference (used for self-deploy and agent deployment)
HIVE_IMAGE=ghcr.io/lholliger/hive:latest

# Set to "true" when running as a Swarm-managed service (set automatically)
# HIVE_MANAGED=true

# ── Ingress / Cloudflare ─────────────────────────────────────────────
# Ingress mode: port_forward | cloudflare_tunnel | both
HIVE_INGRESS_MODE=port_forward

# Cloudflare API token (required for DNS challenges and tunnels)
# HIVE_CF_API_TOKEN=

# Cloudflare tunnel token (for cloudflare_tunnel ingress mode)
# HIVE_CF_TUNNEL_TOKEN=

# Cloudflare zone ID
# HIVE_CF_ZONE_ID=

# ── Registry ─────────────────────────────────────────────────────────
# Private registry domain (deployed automatically in multi-node mode)
HIVE_REGISTRY_DOMAIN=registry.hive.local

# Allow insecure (HTTP) registry communication
HIVE_REGISTRY_INSECURE=true

# ── Monitoring ───────────────────────────────────────────────────────
# Agent metrics collection interval in seconds
HIVE_AGENT_INTERVAL=10

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (empty = allow request origin)
# HIVE_ALLOWED_ORIGINS=https://hive.example.com

# ── Webhooks ─────────────────────────────────────────────────────────
# Public base URL for git provider webhook callbacks
# HIVE_WEBHOOK_BASE_URL=https://hive.example.com

# ── UI ───────────────────────────────────────────────────────────────
# Path to pre-built SvelteKit assets
HIVE_UI_DIR=/app/ui
